{
  "serverInfo": {
    "name": "zoro-nags",
    "version": "1.0.0"
  },
  "description": "Zoro Nags MCP server for email/WhatsApp reminders, scheduling, and profile timezone management.",
  "homepage": "https://www.getzoro.com/nag",
  "icon": "https://www.getzoro.com/icon-dark.png",
  "authentication": {
    "required": true,
    "schemes": [
      "bearer"
    ],
    "instructions": "Provide users.verification_token via x-nag-mcp-token header or Authorization: Bearer <token>. Use nag_auth_email to send a sign-in magic link."
  },
  "tools": [
    {
      "name": "nag_email_check",
      "description": "Check whether an email is already registered before sending auth links.",
      "annotations": {
        "title": "Check Nag Email",
        "readOnlyHint": true,
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email to check",
            "format": "email"
          }
        },
        "required": ["email"]
      }
    },
    {
      "name": "nag_request_link",
      "description": "Create account if needed and send a magic-link email (requires confirm_send=true).",
      "annotations": {
        "title": "Request Nag Magic Link",
        "openWorldHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address to authenticate",
            "format": "email"
          },
          "name": {
            "type": "string",
            "description": "Required when email is not yet registered"
          },
          "timezone": {
            "type": "string",
            "description": "Optional IANA timezone to set on the user (e.g. America/New_York)"
          },
          "confirm_send": {
            "type": "boolean",
            "description": "Must be true to actually send the magic-link email (user consent required)"
          }
        },
        "required": ["email", "confirm_send"]
      }
    },
    {
      "name": "nag_auth_email",
      "description": "Email-first sign-in/signup helper that sends a magic link (requires confirm_send=true).",
      "annotations": {
        "title": "Authenticate by Email",
        "openWorldHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address to authenticate",
            "format": "email"
          },
          "name": {
            "type": "string",
            "description": "Required only if email is not registered yet"
          },
          "timezone": {
            "type": "string",
            "description": "Optional IANA timezone for signup/profile"
          },
          "confirm_send": {
            "type": "boolean",
            "description": "Must be true to send the magic link email (user consent required)"
          }
        },
        "required": ["email", "confirm_send"]
      }
    },
    {
      "name": "nag_parse",
      "description": "Parse natural language into a schedule draft.",
      "annotations": {
        "title": "Parse Reminder Text",
        "readOnlyHint": true,
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "What the user wants reminded (e.g. mow lawn every Tuesday)"
          },
          "token": {
            "type": "string",
            "description": "Optional auth token override (users.verification_token). Usually provided via x-nag-mcp-token config."
          },
          "default_channel": {
            "type": "string",
            "description": "Default delivery channel for the draft",
            "enum": ["email", "whatsapp"]
          }
        },
        "required": ["text"]
      }
    },
    {
      "name": "nags_list",
      "description": "List nags by status.",
      "annotations": {
        "title": "List Nags",
        "readOnlyHint": true,
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config."
          },
          "status": {
            "type": "string",
            "description": "Nag status filter",
            "enum": ["active", "archived", "cancelled", "all"],
            "default": "active"
          }
        }
      }
    },
    {
      "name": "nags_sent_log",
      "description": "List recent sent reminder emails from user memory log.",
      "annotations": {
        "title": "List Sent Log",
        "readOnlyHint": true,
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config."
          },
          "nag_id": {
            "type": "string",
            "description": "Optional filter to a single nag UUID"
          },
          "limit": {
            "type": "integer",
            "description": "Max number of log entries to return (1-200)",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      }
    },
    {
      "name": "nags_create",
      "description": "Create a nag reminder.",
      "annotations": {
        "title": "Create Nag"
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config."
          },
          "message": {
            "type": "string",
            "description": "Reminder message body"
          },
          "channel": {
            "type": "string",
            "description": "Delivery channel",
            "enum": ["email", "whatsapp"]
          },
          "frequency": {
            "type": "string",
            "description": "Reminder frequency",
            "enum": ["daily", "weekly", "monthly", "once"]
          },
          "time_hhmm": {
            "type": "string",
            "description": "24h time HH:MM in user timezone",
            "example": "17:00"
          },
          "day_of_week": {
            "type": "integer",
            "description": "Weekly only: 0=Mon … 6=Sun",
            "minimum": 0,
            "maximum": 6
          },
          "day_of_month": {
            "type": "integer",
            "description": "Monthly only: day of month (1-31)",
            "minimum": 1,
            "maximum": 31
          },
          "end_type": {
            "type": "string",
            "description": "End condition",
            "enum": ["forever", "until_date", "occurrences"]
          },
          "until_date": {
            "type": "string",
            "description": "Required when end_type is until_date or once. Format: YYYY-MM-DD"
          },
          "occurrences_max": {
            "type": "integer",
            "description": "Required when end_type is occurrences. Max number of occurrences (>0).",
            "minimum": 1
          },
          "nag_until_done": {
            "type": "boolean",
            "description": "Email only: continue follow-ups until user marks it done"
          },
          "followup_interval_hours": {
            "type": "integer",
            "description": "Hours between follow-ups (1-336). Omit for default from frequency.",
            "minimum": 1,
            "maximum": 336
          }
        },
        "required": ["message", "channel", "frequency", "time_hhmm", "end_type"]
      }
    },
    {
      "name": "nags_update",
      "description": "Update a nag (schedule/message/status/task completion).",
      "annotations": {
        "title": "Update Nag",
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "nag_id": {
            "type": "string",
            "description": "Nag UUID to update"
          },
          "token": {
            "type": "string",
            "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config."
          },
          "message": { "type": "string", "description": "Updated reminder message" },
          "channel": { "type": "string", "description": "Delivery channel", "enum": ["email", "whatsapp"] },
          "frequency": { "type": "string", "description": "Reminder frequency", "enum": ["daily", "weekly", "monthly", "once"] },
          "time_hhmm": { "type": "string", "description": "24h time HH:MM in user timezone" },
          "day_of_week": { "type": "integer", "description": "Weekly only: 0=Mon … 6=Sun", "minimum": 0, "maximum": 6 },
          "day_of_month": { "type": "integer", "description": "Monthly only: day of month (1-31)", "minimum": 1, "maximum": 31 },
          "end_type": { "type": "string", "description": "End condition", "enum": ["forever", "until_date", "occurrences"] },
          "until_date": { "type": "string", "description": "YYYY-MM-DD when end_type requires it" },
          "occurrences_max": { "type": "integer", "description": "Occurrences max when end_type=occurrences", "minimum": 1 },
          "status": { "type": "string", "description": "Update nag lifecycle state", "enum": ["active", "archived", "cancelled"] },
          "nag_until_done": { "type": "boolean", "description": "Email only: follow up until user marks done" },
          "followup_interval_hours": {
            "type": ["integer", "null"],
            "description": "Hours between follow-ups (1-336) or null to clear",
            "minimum": 1,
            "maximum": 336
          },
          "task_completed": { "type": "boolean", "description": "Mark current cycle done; reschedules to next main occurrence (do not combine with schedule fields)" }
        },
        "required": ["nag_id"]
      }
    },
    {
      "name": "nags_delete",
      "description": "Cancel a nag reminder.",
      "annotations": {
        "title": "Cancel Nag",
        "destructiveHint": true,
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "nag_id": { "type": "string", "description": "Nag UUID to cancel" },
          "token": { "type": "string", "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config." }
        },
        "required": ["nag_id"]
      }
    },
    {
      "name": "nag_reset_token",
      "description": "Rotate a user's nag token.",
      "annotations": {
        "title": "Reset Nag Token",
        "destructiveHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config."
          }
        }
      }
    },
    {
      "name": "user_data_get",
      "description": "Fetch user profile and shared_data.",
      "annotations": {
        "title": "Get User Data",
        "readOnlyHint": true,
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config."
          }
        }
      }
    },
    {
      "name": "nag_profile_set_timezone",
      "description": "Set user timezone for future scheduling.",
      "annotations": {
        "title": "Set Nag Timezone",
        "idempotentHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "timezone": { "type": "string", "description": "IANA timezone e.g. America/New_York" },
          "token": { "type": "string", "description": "Auth token (users.verification_token). Usually provided via x-nag-mcp-token config." }
        },
        "required": ["timezone"]
      }
    }
  ],
  "resources": [
    {
      "name": "nag_api_reference",
      "uri": "https://www.getzoro.com/docs/nag/api",
      "description": "HTTP API behavior, payloads, and error semantics."
    }
  ],
  "prompts": [
    {
      "name": "nag_onboard_user",
      "description": "Onboard a user by checking email registration and sending a magic link."
    },
    {
      "name": "nag_create_from_text",
      "description": "Turn a plain-English reminder request into a draft, then create the nag."
    },
    {
      "name": "nag_triage_overdue",
      "description": "Review active nags, identify overdue or noisy items, and suggest updates."
    }
  ]
}
